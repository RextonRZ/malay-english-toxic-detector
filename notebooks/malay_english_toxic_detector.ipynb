    changes_shown = 0
    for idx in range(len(df)):
        before = df.loc[idx, 'text']
        after = df.loc[idx, 'text_clean']
        if before != after:
            print(f"BEFORE: {before[:150]}")
            print(f"AFTER:  {after[:150]}")
            print()
            changes_shown += 1
        if changes_shown >= max_examples:
            break

